APP_NAME="Smart IoT On-Prem API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Database Configuration
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=smart_iot
DB_USERNAME=postgres
DB_PASSWORD=

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Session Configuration (for Sanctum SPA)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# Sanctum SPA Configuration
SANCTUM_STATEFUL_DOMAINS=api.example.com,www.example.com
SANCTUM_TOKEN_PREFIX=

# CORS Configuration
FRONTEND_URL=https://www.example.com
CORS_ALLOWED_ORIGINS=https://www.example.com,https://app.example.com

# Internal API Token (for backend services)
INTERNAL_API_TOKEN=change-this-to-a-secure-random-token

# Cache Configuration
CACHE_STORE=redis
CACHE_PREFIX=

# Queue Configuration
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default

# Logging Configuration
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Mail Configuration (optional)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting (optional)
BROADCAST_DRIVER=log

# Filesystem
FILESYSTEM_DISK=local

# Outbox Publisher (optional - for scheduled publishing)
OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_PUBLISHER_BATCH_SIZE=100
OUTBOX_PUBLISHER_MAX_ATTEMPTS=3
