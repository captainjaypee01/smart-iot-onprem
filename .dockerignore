# .dockerignore — project root
# Prevents unnecessary files being sent to the Docker build context

# Dependencies (rebuilt inside container)
iot-dashboard/node_modules
api/vendor

# Git / IDE
.git
.gitignore
**/.DS_Store
**/*.swp

# Env files — never bake secrets into images
.env*
api/.env*
iot-dashboard/.env*

# Logs and storage
api/storage/logs
api/storage/framework/cache
api/storage/framework/sessions
api/storage/framework/views

# Observability configs not needed in app builds
observability/