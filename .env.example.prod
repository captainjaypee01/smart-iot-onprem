# .env.prod — Production environment variables
# NEVER commit this file. Use a secret manager (Vault, AWS Secrets Manager, etc.)
# Inject all values via CI/CD pipeline or Docker secrets.

APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:REPLACE_WITH_REAL_KEY_FROM_ARTISAN
APP_URL=https://api.your-domain.com

# Postgres — use strong 32+ char password
POSTGRES_DB=iot
POSTGRES_USER=iot
POSTGRES_PASSWORD=REPLACE_VERY_STRONG_PASSWORD
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=REPLACE_VERY_STRONG_REDIS_PASSWORD
REDIS_MAXMEMORY=1gb
REDIS_PORT=6379

# MQTT
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USER=iot_prod
MQTT_PASSWORD=REPLACE_MQTT_PASSWORD

# API
API_PORT=8000
INTERNAL_API_TOKEN=REPLACE_INTERNAL_TOKEN_64CHAR
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=your-domain.com
FRONTEND_URL=https://your-domain.com

# Dashboard
DASHBOARD_PORT=5173
VITE_USE_MOCK=false

# Observability
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=90d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=REPLACE_GRAFANA_USER
GRAFANA_ADMIN_PASSWORD=REPLACE_VERY_STRONG_GRAFANA_PASSWORD
GRAFANA_SECRET_KEY=REPLACE_GRAFANA_SECRET_64CHAR_RANDOM
GRAFANA_ROOT_URL=https://grafana.your-domain.com
GF_LOG_LEVEL=error
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
