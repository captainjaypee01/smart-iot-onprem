meta {
  name: List Gateways
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/gateways
  body: none
  auth: bearer
}

auth:bearer {
  token: {{sanctumToken}}
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("has data array", function() {
    expect(res.getBody()).to.have.property("data");
    expect(res.getBody().data).to.be.an("array");
  });
  test("has meta", function() {
    expect(res.getBody()).to.have.property("meta");
  });
  test("has links", function() {
    expect(res.getBody()).to.have.property("links");
  });
}
