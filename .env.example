# .env.dev — Development environment variables
# Copy to .env and adjust. Never commit real secrets.

APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_ARTISAN_KEY_GENERATE
APP_URL=http://localhost:8000

# Postgres
POSTGRES_DB=smart_iot_onprem
POSTGRES_USER=iot
POSTGRES_PASSWORD=iotpass
POSTGRES_PORT=5432
POSTGRES_EXPORTER_DSN=postgresql://iot:iotpass@postgres:5432/smart_iot_onprem?sslmode=disable

# Redis
REDIS_PASSWORD=devredis123
REDIS_MAXMEMORY=256mb
REDIS_PORT=6379

# MQTT
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USER=iotdev
MQTT_PASSWORD=mqttdev123

# API
API_PORT=8000
INTERNAL_API_TOKEN=dev-internal-token-change-me
SESSION_SECURE_COOKIE=false
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173
FRONTEND_URL=http://localhost:5173

# Dashboard
DASHBOARD_PORT=5173
VITE_USE_MOCK=true

# Observability
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=7d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_SECRET_KEY=dev-grafana-secret-change-me
GRAFANA_ROOT_URL=http://localhost:3000
GF_LOG_LEVEL=info
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
